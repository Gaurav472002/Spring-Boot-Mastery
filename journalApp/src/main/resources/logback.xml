<appender name = "myFileAppender" class = "ch.qos.logback.core.FileAppender">

    <encoder>
        <pattern>
            %d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n
        </pattern>
    </encoder>
    <file>

<!--        You can provide the destination along with the file name where you want to generate the log-->
        jounrnalApp.log
    </file>
</appender>


    <root level ="INFO">
        <appender-ref ref ="myConsoleAppender" />
        <appender-ref ref ="myFileAppender" />
    </root>


</configuration>